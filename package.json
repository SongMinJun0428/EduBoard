{
  "name": "eduboard-app",
  "version": "1.0.0",
  "description": "EduBoard Android & Windows App App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:exe": "npx electron-builder --win",
    "build:android": "npx cap sync android"
  },
  "author": "EduBoard Team",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^5.0.0",
    "@capacitor/core": "^5.0.0",
    "@capacitor/ios": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.antigravity.eduboard",
    "productName": "EduBoard",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    }
  }
}
